# --- Database (Railway MySQL - cole a URL gerada pelo Railway) ---
DATABASE_URL="mysql://root:password@mysql.railway.internal:3306/railway"

# --- JWT ---
JWT_SECRET="troque_por_uma_senha_aleatoria_longa_e_segura"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."

# --- Instagram / Facebook App ---
INSTAGRAM_APP_ID="seu_app_id"
INSTAGRAM_APP_SECRET="seu_app_secret"

# --- URLs (Railway preencherá automaticamente a porta) ---
# Cole a URL pública do serviço frontend gerada pelo Railway
FRONTEND_URL="https://seu-frontend.up.railway.app"
BACKEND_URL="https://seu-backend.up.railway.app"

# --- Redis (opcional - remova se não usar) ---
# REDIS_URL="redis://..."

# --- Node ---
NODE_ENV="production"
PORT=3000
